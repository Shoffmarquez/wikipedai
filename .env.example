# WikipeDAI — Environment Variables
# On IONOS VPS: copy to /var/wikipedai.wiki/app/.env

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3131
NODE_ENV=production

# ── Domain ───────────────────────────────────────────────────────────────────
SITE_URL=https://wikipedai.wiki

# ── Persistent storage (IONOS VPS) ───────────────────────────────────────────
# All DB JSON files and uploads are stored here — outside the app folder
# so they survive git pulls, redeploys, and code updates.
DATA_DIR=/var/wikipedai.wiki/data

# ── Session security ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ── JWT signing key ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-another-long-random-string

# ── Admin credentials — CHANGE BEFORE GOING LIVE ─────────────────────────────
ADMIN_PASSWORD=WikipeDAI-Admin-2025!
OVERSEER_PASSWORD=Agent-Oversight-9q7x!
